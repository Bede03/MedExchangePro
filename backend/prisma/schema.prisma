// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  fullName      String   @map("full_name")
  email         String   @unique
  password      String
  role          UserRole
  hospitalId    String   @map("hospital_id")
  hospital      Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  auditLogs     AuditLog[]

  @@map("users")
}

enum UserRole {
  admin
  clinician
  registrar
  hospital_staff

  @@map("user_role")
}

model Hospital {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  users                  User[]
  patients               Patient[]
  departments            HospitalDepartment[]
  
  referralsRequesting    Referral[] @relation("requestingHospital")
  referralsReceiving     Referral[] @relation("receivingHospital")
  sharedPatientRecords   SharedPatientRecord[]

  @@map("hospitals")
}

model HospitalDepartment {
  id        String   @id @default(cuid())
  hospitalId String  @map("hospital_id")
  hospital  Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  
  departmentName  String  @map("department_name")
  category        String  // e.g., "Surgery", "Cardiology", "Internal Medicine"
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@unique([hospitalId, departmentName])
  @@map("hospital_departments")
}

model Patient {
  id            String   @id @default(cuid())
  name          String
  gender        Gender
  dob           String   // ISO date
  phone         String
  address       String
  nationalId    String   @unique @map("national_id")
  hospitalId    String   @map("hospital_id")
  hospital      Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  referrals              Referral[]
  sharedRecords          SharedPatientRecord[]

  @@map("patients")
}

enum Gender {
  male
  female
  other

  @@map("gender")
}

model Referral {
  id                      String                @id @default(cuid())
  patientId               String                @map("patient_id")
  patient                 Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  reason                  String
  status                  ReferralStatus        @default(pending)
  priority                ReferralPriority
  department              String                @map("department") // Required department
  
  requestingHospitalId    String                @map("requesting_hospital_id")
  requestingHospital      Hospital              @relation("requestingHospital", fields: [requestingHospitalId], references: [id], onDelete: Restrict)
  
  receivingHospitalId     String                @map("receiving_hospital_id")
  receivingHospital       Hospital              @relation("receivingHospital", fields: [receivingHospitalId], references: [id], onDelete: Restrict)
  
  sharedPatientRecords    SharedPatientRecord[]
  
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  completedAt             DateTime?             @map("completed_at")

  @@map("referrals")
}

enum ReferralStatus {
  pending
  approved
  completed
  rejected

  @@map("referral_status")
}

enum ReferralPriority {
  Emergency
  Urgent
  Routine

  @@map("referral_priority")
}

model AuditLog {
  id            String           @id @default(cuid())
  action        AuditAction
  entityType    AuditEntityType  @map("entity_type")
  entityId      String           @map("entity_id")
  
  userId        String           @map("user_id")
  user          User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  ipAddress     String?          @map("ip_address")
  userAgent     String?          @map("user_agent")
  details       Json?
  status        String           @default("success")
  
  timestamp     DateTime         @default(now())

  @@map("audit_logs")
  @@index([userId])
  @@index([entityId])
  @@index([timestamp])
}

enum AuditAction {
  User_Updated
  Status_Changed
  User_Created
  Data_Accessed
  Referral_Created
  Referral_Approved
  Referral_Rejected
  Patient_Created
  Patient_Updated
  Login
  Logout

  @@map("audit_action")
}

enum AuditEntityType {
  User
  Referral
  Patient
  Hospital

  @@map("audit_entity_type")
}

model SharedPatientRecord {
  id                    String   @id @default(cuid())
  referralId            String   @map("referral_id")
  referral              Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  
  patientId             String   @map("patient_id")
  patient               Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  receivingHospitalId   String   @map("receiving_hospital_id")
  receivingHospital     Hospital @relation(fields: [receivingHospitalId], references: [id], onDelete: Cascade)
  
  // Medical records
  testResults           String?  @map("test_results")
  medications           String?  @map("medications")
  allergies             String?  @map("allergies")
  medicalHistory        String?  @map("medical_history")
  vitalsLastRecorded    String?  @map("vitals_last_recorded")
  currentDiagnosis      String?  @map("current_diagnosis")
  clinicalNotes         String?  @map("clinical_notes")
  
  sharedAt              DateTime @default(now()) @map("shared_at")
  accessedAt            DateTime @updatedAt @map("accessed_at")
  expiresAt             DateTime @map("expires_at") // Auto-expire after 30 days
  
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("shared_patient_records")
  @@index([referralId])
  @@index([patientId])
  @@index([receivingHospitalId])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  userId    String?
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

enum NotificationType {
  info
  success
  warning
  error

  @@map("notification_type")
}
